{
    "endpoint": "POST /hierarchy/create",
    "description": "Generation: Create a new nested hierarchy structure from scratch. Optionally mounts the root of this new tree to an existing parentId.",
    "request_body": {
        "parentId": "Hash32 (optional, if mounting to existing unit)",
        "hierarchy": [
            {
                "label": "string (required)",
                "payload": "object (optional, default: {})",
                "order": "integer (optional, only needed when mounting, default when mounting: last)",
                "children": [
                    {
                        "label": "string (required)",
                        "payload": "object (optional)",
                        "order": "integer (required)",
                        "children": "recursive Hierarchy structure..."
                    },
                    {
                        "mountId": "32bit",
                        "width": "int",
                        "depth": "int",
                        "overrides": [
                            {
                                "mountId": "int32",
                                "overrideId": "int32"
                            }
                        ],
                        "overlays": [
                            {
                                "mountId": "int32",
                                "overlayId": "int32"
                            }
                        ]
                    }
                ]
            }
        ]
    },
    "response": {
        "status": 201,
        "body": {
            "rootId": "Hash32",
            "structure": [
                {
                    "id": "Hash32",
                    "label": "string",
                    "payload": "object",
                    "order": "integer",
                    "children": "..."
                }
            ]
        }
    }
}