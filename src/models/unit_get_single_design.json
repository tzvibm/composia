{
    "endpoint": "GET /units/:id",
    "description": "Fetch a single atomic unit by its unique identifier",
    "parameters": {
        "id": "Hash32 (path parameter)"
    },
    "response": {
        "status": 200,
        "body": {
            "id": "Hash32",
            "label": "string",
            "payload": "object",
            "created_at": "ISO-8601"
        }
    },
    "error_response": {
        "status": 404,
        "body": { "error": "Unit not found" }
    }
}