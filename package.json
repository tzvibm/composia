{
  "name": "composia-native",
  "version": "1.0.0",
  "type": "module",
  "main": "index.js",
  "napi": {
    "binaryName": "composia_native",
    "packageName": "composia-native"
  },
  "scripts": {
    "artifacts": "napi build --platform --release",
    "build": "napi build --release",
    "build:debug": "napi build",
    "prestart": "npm run build",
    "start": "NODE_ENV=production node src/app.js",
    "dev": "NODE_ENV=development node src/app.js",
    "test": "NODE_ENV=test vitest run --no-file-parallelism",
    "test:watch": "NODE_ENV=test vitest --no-file-parallelism"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.0.0",
    "lodash": "^4.17.23",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.0.0",
    "vitest": "^2.1.0"
  }
}
